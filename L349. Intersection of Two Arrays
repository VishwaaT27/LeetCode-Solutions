class Solution 
{
    public int[] intersection(int[] nums1, int[] nums2) 
    {
        Set<Integer> s = new HashSet<>(nums1.length);
        for (int x : nums1) s.add(x);
        Set<Integer> l = new HashSet<>();       
        for (int x : nums2) if (s.contains(x)) l.add(x);
        int[] r = new int[l.size()];
        int i = 0;
        for (int x : l) r[i++] = x; 
        return r;
    }
}
